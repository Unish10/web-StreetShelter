# Server Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=streetshelter
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secret (Change this to a secure random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Email Configuration (for OTP/Password Reset)
# For Gmail: use 'gmail', for Outlook: use 'outlook', etc.
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
# Note: For Gmail, you need to create an "App Password" from your Google Account settings
# Leave these empty to use Ethereal (test email service) in development
