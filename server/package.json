{
  "name": "streetshelter-backend",
  "version": "1.0.0",
  "description": "Backend API for StreetShelter dog reporting system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:routes": "cross-env NODE_ENV=test jest __tests__/routes",
    "test:models": "cross-env NODE_ENV=test jest __tests__/models",
    "test:verbose": "cross-env NODE_ENV=test jest --verbose"
  },
  "keywords": [
    "express",
    "postgresql",
    "api",
    "dog-shelter"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "sqlite3": "^5.1.7",
    "supertest": "^7.2.2"
  }
}
